{
	"extends": [ "plugin:@wordpress/eslint-plugin/recommended" ],
	"env": {
		"browser": true
	},
	"globals": {
		"wc": true,
		"jQuery": "readonly"
	},
	"rules": {
		"no-console": ["error", { "allow": ["warn", "error"] }]
	},
	"settings": {
		"import/resolver": {
			"webpack": {
				"config": "./webpack.config.js"
			}
		}
	}
}
