root = true

[*]
indent_style = tab
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 100

[*.{md,txt}]
trim_trailing_whitespace = false

[*.{js,json,yml}]
indent_style = space

[*.yml]
indent_size = 2

[*.php]
ij_php_variable_naming_style = snake_case
ij_php_getters_setters_naming_style = snake_case
